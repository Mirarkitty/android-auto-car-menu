<?xml version="1.0" encoding="utf-8"?>
<!-- Monochrome layer for Android 13+ themed icons. Must be flat one-color
     (alpha-only; the system tints it to match the user's wallpaper). Same
     compass-rose silhouette as the foreground, drawn in a single fill so
     the OS can apply its own tint. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108"
    android:tint="?attr/colorControlNormal">

    <!-- Outer ring -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="1.5"
        android:fillColor="#00000000"
        android:pathData="M54,18 A36,36 0 1,1 53.99,18 Z" />

    <!-- Compass rose — single fill, 8 points alternating outer/inner. -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M54,18 L58,45 L71,37 L63,50 L90,54 L63,58 L71,71 L58,63
            L54,90 L50,63 L37,71 L45,58 L18,54 L45,50 L37,37 L50,45 Z" />

    <!-- Center pip (subtract — drawn with the background gap color so it
         shows through whatever tint the OS applied). We approximate by
         drawing it transparent over an even-odd path; simplest is to use
         a small ring path. -->
    <path
        android:strokeColor="#FFFFFF"
        android:strokeWidth="2"
        android:fillColor="#00000000"
        android:pathData="M54,51 m-2.5,0 a2.5,2.5 0,1,0 5,0 a2.5,2.5 0,1,0 -5,0 Z" />
</vector>
