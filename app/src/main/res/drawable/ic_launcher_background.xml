<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive-icon background layer. 108x108 viewport, but the OS may clip
     out up to 18dp on any side (depends on the device's icon mask shape).
     Keep the rich detail near the center; the corners get cropped on
     circle/squircle masks. -->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Deep nautical navy base. -->
    <path
        android:fillColor="#0E2538"
        android:pathData="M0,0h108v108h-108z" />

    <!-- Subtle radial highlight at center — gives the icon depth on
         circular masks without competing with the compass rose. -->
    <path android:pathData="M0,0h108v108h-108z">
        <aapt:attr xmlns:aapt="http://schemas.android.com/aapt" name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="60"
                android:startColor="#22FFFFFF"
                android:endColor="#00000000" />
        </aapt:attr>
    </path>
</vector>
