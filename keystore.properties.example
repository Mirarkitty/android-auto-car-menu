# Copy to keystore.properties (gitignored) and fill in.
# `make keygen` will generate the keystore + this file for you.
#
# For Play publishing, the Play console will manage the *release* signing
# key automatically — we only ever hold the *upload* key. So this
# keystore is the upload key. Same shared keystore works for debug builds
# too (we override the auto-generated debug.keystore — see
# app/build.gradle.kts).

storeFile=keystore.jks
storePassword=CHANGE_ME
keyAlias=carmenu
keyPassword=CHANGE_ME
